# Copy this file to .env and fill in the keys you have.
# .env is gitignored. Only the keys you actually use need values.

# ----- LLM providers (pick one or more) -----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Default LLM provider (anthropic | openai | gemini | openrouter | ollama)
CALLIMACHUS_LLM_PROVIDER=anthropic

# ----- OCR -----
MISTRAL_API_KEY=

# ----- Discovery sources -----
EXA_API_KEY=
PERPLEXITY_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# ----- Embeddings (optional upgrade; default is local nomic) -----
VOYAGE_API_KEY=

# ----- Library location -----
# Default is ~/Callimachus. Override here if you want it elsewhere.
# CALLIMACHUS_LIBRARY=~/Callimachus

# ----- Notifications (optional) -----
# CALLIMACHUS_NOTIFY=desktop
# CALLIMACHUS_WEBHOOK_URL=
