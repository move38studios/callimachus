# Copy this file to .env and fill in the keys you have.
# .env is gitignored. Only the keys you actually use need values.

# ----- LLM providers -----
# OpenRouter is the recommended default — one key gives access to Claude,
# GPT, Gemini, open-weight models, etc. Set just OPENROUTER_API_KEY for the
# usual case. The other keys are only needed if you want to skip OpenRouter
# and call a provider directly.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Default LLM provider (openrouter | anthropic | openai | gemini | ollama)
CALLIMACHUS_LLM_PROVIDER=openrouter

# ----- OCR -----
MISTRAL_API_KEY=

# ----- Discovery sources -----
EXA_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# Perplexity is reached via OpenRouter by default (perplexity/sonar etc.) —
# no separate key needed for the usual case. Set this only if you want to
# call Perplexity's API directly (different rate limits / native features).
PERPLEXITY_API_KEY=

# ----- Embeddings (optional upgrade; default is local nomic) -----
VOYAGE_API_KEY=

# ----- Library location -----
# Default is ~/Callimachus. Override here if you want it elsewhere.
# CALLIMACHUS_LIBRARY=~/Callimachus

# ----- Notifications (optional) -----
# CALLIMACHUS_NOTIFY=desktop
# CALLIMACHUS_WEBHOOK_URL=
